def log_args(func):
    def wrapper(*args, **kwargs):
        print("Argumenter:", *args)
        result = func(*args, **kwargs)
        print("The Answer to the Ultimate Question of Life, The Universe, and Everything")
        return result
    return wrapper

@log_args
def multiply(a, b):
    return a * b

print("The result is:", multiply(6, 7))
